{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "angular",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npm run start",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://inventory-api.onrender.com/api/:path*"
    }
  ]
}
